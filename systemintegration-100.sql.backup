--
-- Triggers `eims_transactions`
--
DELIMITER $$
CREATE TRIGGER `trg_update_equipment_on_borrow` AFTER UPDATE ON `eims_transactions` FOR EACH ROW BEGIN
    IF NEW.status = 'Borrowed' AND OLD.status = 'Request' THEN
        UPDATE eims_equipment 
        SET status = 'Borrowed',
            available_quantity = available_quantity - NEW.quantity
        WHERE equipment_id = NEW.equipment_id;
    END IF;
END
$$
DELIMITER ;
DELIMITER $$
CREATE TRIGGER `trg_update_equipment_on_return` AFTER UPDATE ON `eims_transactions` FOR EACH ROW BEGIN
    IF NEW.status = 'Returned' AND OLD.status IN ('Borrowed', 'Overdue') THEN
        UPDATE eims_equipment 
        SET available_quantity = available_quantity + NEW.quantity
        WHERE equipment_id = NEW.equipment_id;
        
        -- Update equipment status to Available if no active borrows
        UPDATE eims_equipment e
        SET e.status = 'Available'
        WHERE e.equipment_id = NEW.equipment_id
        AND NOT EXISTS (
            SELECT 1 FROM eims_transactions t 
            WHERE t.equipment_id = NEW.equipment_id 
            AND t.status IN ('Borrowed', 'Request')
        );
    END IF;
END
$$
DELIMITER ;

