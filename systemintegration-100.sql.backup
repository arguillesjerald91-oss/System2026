--
-- Table structure for table `applications`
--

CREATE TABLE `applications` (
  `id` int(11) NOT NULL,
  `user_id` int(11) NOT NULL,
  `application_type` enum('scholarship','tdp') DEFAULT 'scholarship',
  `school_id` varchar(20) NOT NULL,
