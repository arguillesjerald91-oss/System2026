--
-- Table structure for table `announcement`
--

CREATE TABLE `announcement` (
  `AnnouncementID` int(11) NOT NULL,
  `schedule_id` int(11) DEFAULT NULL,
  `Title` varchar(255) NOT NULL,
  `Content` text NOT NULL,
  `target_audience` enum('all','student','admin') DEFAULT 'all',
  `PostedBy` int(11) NOT NULL,
  `PostedAt` timestamp NOT NULL DEFAULT current_timestamp(),
  `UpdatedAt` timestamp NOT NULL DEFAULT current_timestamp() ON UPDATE current_timestamp(),
  `IsPublished` tinyint(1) DEFAULT 1,
  `Priority` enum('low','normal','high','urgent') DEFAULT 'normal',
  `status` enum('active','inactive') DEFAULT 'active',
  `start_date` date DEFAULT NULL,
  `end_date` date DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

--
-- Dumping data for table `announcement`
--

INSERT INTO `announcement` (`AnnouncementID`, `schedule_id`, `Title`, `Content`, `target_audience`, `PostedBy`, `PostedAt`, `UpdatedAt`, `IsPublished`, `Priority`, `status`, `start_date`, `end_date`) VALUES
(1, NULL, 'Scholarship Application Deadline', 'Due to numerous requests, the deadline for scholarship applications has been extended to December 15, 2024. Please ensure all required documents are submitted before the new deadline.', 'student', 17, '2026-01-12 21:48:13', '2026-01-12 21:48:13', 1, 'high', 'active', '2024-11-01', '2024-12-15'),
(2, NULL, 'Scholarship Allowance Release', 'The scholarship allowance for the month of November will be released on November 25, 2024. Please ensure your bank account details are updated in the system.', 'student', 17, '2026-01-12 21:48:13', '2026-01-12 21:48:13', 1, 'urgent', 'active', '2024-11-01', '2024-11-25'),
(3, NULL, 'Scholarship Academic Requirements', 'All scholars are required to submit their mid-term grades by November 30, 2024. Failure to submit may affect your scholarship status.', 'student', 17, '2026-01-12 21:48:13', '2026-01-12 21:48:13', 1, 'high', 'active', '2024-11-10', '2024-11-30'),
(4, NULL, 'Scholarship Application Status Update', 'The scholarship committee has completed the initial review of applications. Shortlisted candidates will be notified for interviews next week.', 'student', 17, '2026-01-12 21:48:13', '2026-01-12 21:48:13', 1, 'normal', 'active', '2024-11-01', NULL),
(5, NULL, 'Scholarship Renewal Process', 'The scholarship renewal process for the next academic year will begin on January 15, 2024. Please prepare all necessary documents.', 'student', 17, '2026-01-12 21:48:13', '2026-01-12 21:48:13', 1, 'high', 'active', '2024-01-01', '2024-02-15'),
(6, NULL, 'TDP Application Now Open', 'Applications for Tertiary Education Subsidy (TDP) are now open for AY 2024-2025. Eligible students from families with annual income ≤ ₱300,000 may apply.', 'student', 17, '2026-01-12 22:54:10', '2026-01-12 22:54:10', 1, 'high', 'active', '2024-11-01', '2024-12-31'),
(7, NULL, 'TDP Requirements Deadline', 'Deadline for submitting complete TDP application requirements is December 15, 2024. Ensure all documents including proof of income and certificate of indigency are submitted.', 'student', 17, '2026-01-12 22:54:10', '2026-01-12 22:54:10', 1, 'urgent', 'active', '2024-11-15', '2024-12-15'),
(8, NULL, 'TDP Verification Schedule', 'TDP application verification will begin on January 15, 2025. Shortlisted applicants will be notified for interview.', 'student', 17, '2026-01-12 22:54:10', '2026-01-12 22:54:10', 1, 'high', 'active', '2025-01-01', '2025-02-15'),
(9, NULL, 'TDP Stipend Release', 'First month TDP stipend for approved applicants will be released on February 15, 2025.', 'student', 17, '2026-01-12 22:54:10', '2026-01-12 22:54:10', 1, 'urgent', 'active', '2025-02-01', '2025-02-15'),
(10, NULL, 'TDP Application Now Open', 'Applications for Tertiary Education Subsidy (TDP) are now open for AY 2024-2025. Eligible students from families with annual income ≤ ₱300,000 may apply.', 'student', 17, '2026-01-12 23:18:06', '2026-01-12 23:18:06', 1, 'high', 'active', '2024-11-01', '2024-12-31'),
(11, NULL, 'TDP Requirements Deadline', 'Deadline for submitting complete TDP application requirements is December 15, 2024. Ensure all documents including proof of income and certificate of indigency are submitted.', 'student', 17, '2026-01-12 23:18:06', '2026-01-12 23:18:06', 1, 'urgent', 'active', '2024-11-15', '2024-12-15'),
(12, NULL, 'TDP Verification Schedule', 'TDP application verification will begin on January 15, 2025. Shortlisted applicants will be notified for interview.', 'student', 17, '2026-01-12 23:18:06', '2026-01-12 23:18:06', 1, 'high', 'active', '2025-01-01', '2025-02-15'),
(13, NULL, 'TDP Stipend Release', 'First month TDP stipend for approved applicants will be released on February 15, 2025.', 'student', 17, '2026-01-12 23:18:06', '2026-01-12 23:18:06', 1, 'urgent', 'active', '2025-02-01', '2025-02-15');

