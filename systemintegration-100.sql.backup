--
-- Structure for view `all_users_view`
--
DROP TABLE IF EXISTS `all_users_view`;

CREATE ALGORITHM=UNDEFINED DEFINER=`root`@`localhost` SQL SECURITY DEFINER VIEW `all_users_view`  AS SELECT `u`.`username` AS `username`, `u`.`password` AS `password`, `u`.`role` AS `role`, `u`.`user_ref_id` AS `user_ref_id`, `u`.`created_at` AS `created_at` FROM `class_users` AS `u` ;

-- --------------------------------------------------------

--
-- Structure for view `v_equipment_details`
--
DROP TABLE IF EXISTS `v_equipment_details`;

CREATE ALGORITHM=UNDEFINED DEFINER=`root`@`localhost` SQL SECURITY DEFINER VIEW `v_equipment_details`  AS SELECT `e`.`equipment_id` AS `equipment_id`, `e`.`name` AS `name`, `e`.`serial_number` AS `serial_number`, `e`.`quantity` AS `quantity`, `e`.`available_quantity` AS `available_quantity`, `e`.`location` AS `location`, `e`.`condition` AS `condition`, `e`.`status` AS `status`, `e`.`remarks` AS `remarks`, `c`.`category_name` AS `category_name`, `e`.`created_at` AS `created_at`, `e`.`updated_at` AS `updated_at` FROM (`eims_equipment` `e` left join `eims_categories` `c` on(`e`.`category_id` = `c`.`category_id`)) ;

-- --------------------------------------------------------

--
-- Structure for view `v_transaction_details`
--
DROP TABLE IF EXISTS `v_transaction_details`;

CREATE ALGORITHM=UNDEFINED DEFINER=`root`@`localhost` SQL SECURITY DEFINER VIEW `v_transaction_details`  AS SELECT `t`.`transaction_id` AS `transaction_id`, `t`.`equipment_id` AS `equipment_id`, `e`.`name` AS `equipment_name`, `t`.`borrower_id` AS `borrower_id`, `u1`.`full_name` AS `borrower_name`, `u1`.`email` AS `borrower_email`, `u1`.`user_type` AS `user_type`, `u1`.`student_id` AS `student_id`, `u1`.`instructor_id` AS `instructor_id`, `t`.`quantity` AS `quantity`, `t`.`borrow_date` AS `borrow_date`, `t`.`due_date` AS `due_date`, `t`.`return_date` AS `return_date`, `t`.`status` AS `status`, `t`.`purpose` AS `purpose`, `t`.`remarks` AS `remarks`, `u2`.`full_name` AS `recorded_by_name`, `u3`.`full_name` AS `approved_by_name`, `t`.`created_at` AS `created_at` FROM ((((`eims_transactions` `t` join `eims_equipment` `e` on(`t`.`equipment_id` = `e`.`equipment_id`)) join `eims_users` `u1` on(`t`.`borrower_id` = `u1`.`user_id`)) left join `eims_users` `u2` on(`t`.`recorded_by_id` = `u2`.`user_id`)) left join `eims_users` `u3` on(`t`.`approved_by` = `u3`.`user_id`)) ;

