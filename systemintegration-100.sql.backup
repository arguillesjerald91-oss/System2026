--
-- Triggers `document_requests`
--
DELIMITER $$
CREATE TRIGGER `check_completion_date` BEFORE UPDATE ON `document_requests` FOR EACH ROW BEGIN
  IF NEW.Completion_date IS NOT NULL
     AND NEW.Completion_date < NEW.Request_date THEN
    SIGNAL SQLSTATE '45000'
    SET MESSAGE_TEXT = 'Completion date cannot be before request date';
  END IF;
END
$$
DELIMITER ;
DELIMITER $$
CREATE TRIGGER `trg_count_daily_request` BEFORE INSERT ON `document_requests` FOR EACH ROW BEGIN
  DECLARE today_count INT;
  DECLARE max_limit INT DEFAULT 30;

  INSERT IGNORE INTO request_counters (date) VALUES (CURDATE());

  SELECT count, max_limit
  INTO today_count, max_limit
  FROM request_counters
  WHERE date = CURDATE();

  IF today_count >= max_limit THEN
    SIGNAL SQLSTATE '45000'
    SET MESSAGE_TEXT = 'Daily request limit reached';
  END IF;

  UPDATE request_counters
  SET count = count + 1
  WHERE date = CURDATE();
END
$$
DELIMITER ;
DELIMITER $$
CREATE TRIGGER `validate_status_transition` BEFORE UPDATE ON `document_requests` FOR EACH ROW BEGIN
  IF NOT (
    OLD.Status = NEW.Status OR
    (OLD.Status = 'Pending' AND NEW.Status IN ('Processing','Approved','Rejected')) OR
    (OLD.Status = 'Processing' AND NEW.Status IN ('Approved','Rejected')) OR
    (OLD.Status = 'Approved' AND NEW.Status IN ('Completed','Rejected')) OR
    (OLD.Status = 'Rejected' AND NEW.Status = 'Pending')
  ) THEN
    SIGNAL SQLSTATE '45000'
    SET MESSAGE_TEXT = 'Invalid status transition';
  END IF;
END
$$
DELIMITER ;

